# Copy to .env for local dev. Real values come from Doppler / injected env in
# every shared environment — .env is gitignored and never committed.

ENVIRONMENT=development

# Async (asyncpg) URL — matches docker-compose's postgres service.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/verdantis
REDIS_URL=redis://localhost:6379/0

SENTRY_DSN=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=verdantis-leadgen
LANGSMITH_TRACING=false

CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
